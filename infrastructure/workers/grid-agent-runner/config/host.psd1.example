    LogRoot = "C:\HoneyDrunk\Runtime\grid-agent-runner\logs"
    StateRoot = "C:\HoneyDrunk\Runtime\grid-agent-runner\state"
    CacheRoot = "C:\HoneyDrunk\Runtime\grid-agent-runner\cache"
